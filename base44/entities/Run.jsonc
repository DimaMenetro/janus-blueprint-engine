    "blueprint": {
      "type": "object",
      "properties": {
        "goal": {
          "type": "string"
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alternative_approaches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "pros": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "cons": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "why_not_chosen": {
                "type": "string"
              }
            }
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "step": {
                "type": "number"
              },
              "title": {
                "type": "string"
              },
              "instructions": {
                "type": "string"
              },
              "inputs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "outputs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "validation": {
                "type": "string"
              },
              "depends_on_steps": {
                "type": "array",
                "items": {
                  "type": "number"
                }
              },
              "time_estimate": {
                "type": "string"
              },
              "effort_level": {
                "type": "string"
              },
              "substeps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "substep": {
                      "type": "string"
                    },
                    "details": {
                      "type": "string"
                    }
                  }
                }
              },
              "checklist": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "acceptance_tests": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "success_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risk_register": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "risk": {
                "type": "string"
              },
              "impact": {
                "type": "string"
              },
              "mitigation": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "raw_json": {
      "type": "string",
      "description": "The raw JSON output from the LLM"
    },
    "render_md": {
      "type": "string",
      "description": "Human-readable markdown render of the blueprint"
    },
    "error_message": {
      "type": "string",
      "description": "Error message if validation failed"
    },
    "current_step": {
      "type": "string",
      "description": "IMP-001-R-D-RES Phase 2 \u2014 Stable label of the most recently entered pipeline step (e.g. 'domain:corpus', 'blueprint:expansion', 'synthesis'). Used for resumability and live diagnostics. Optional; absent on legacy runs."
    },
    "last_heartbeat": {
      "type": "string",
      "format": "date-time",
      "description": "IMP-001-R-D-RES Phase 2 \u2014 ISO timestamp updated each time the engine enters a new step or completes a retry. Allows external observers to detect stalled runs. Optional; absent on legacy runs."
    },
    "retry_log": {
      "type": "array",
      "description": "IMP-001-R-D-RES Phase 2 \u2014 Append-only log of LLM retry events for this run.",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "call_label": {
            "type": "string",
            "description": "Stable label from TIMEOUT_MATRIX (e.g. 'blueprint:expansion')"
          },
          "attempt": {
            "type": "number",
            "description": "1-indexed attempt number when the failure occurred"
          },
          "error": {
            "type": "string",
            "description": "Error message captured from the failed attempt"
          },
          "will_retry": {
            "type": "boolean",
            "description": "Whether the resilient caller scheduled another attempt"
          },
          "next_delay_ms": {
            "type": "number",
            "description": "Backoff delay before the next attempt (0 if exhausted)"
          }
        }
      }
    },
    "debug_prompt_hashes": {
      "type": "array",
      "description": "IMP-002-R-D-SRV Phase -1 \u2014 TEMPORARY field used only during golden run capture. Stores SHA-256 hashes of each LLM prompt issued during the run. WILL BE REMOVED at end of Phase -1 (subtask -1.8). Optional.",
      "items": {
        "type": "object",
        "properties": {
          "call_label": {
            "type": "string"
          },
          "prompt_hash_sha256": {
            "type": "string"
          },
          "prompt_length": {
            "type": "number"
          },
          "attempt": {
            "type": "number"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "required": [
    "query_text",
    "execution_mode",
    "output_mode"
  ]
}