{
  "name": "Run",
  "type": "object",
  "properties": {
    "query_text": {
      "type": "string",
      "description": "The user's natural language query"
    },
    "full_prompt": {
      "type": "string",
      "description": "The complete prompt sent to the LLM"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "quick",
        "standard",
        "full"
      ],
      "default": "standard",
      "description": "Execution mode: quick, standard, or full"
    },
    "output_mode": {
      "type": "string",
      "enum": [
        "Blueprint",
        "Research Plan",
        "Product Spec",
        "Technical Architecture"
      ],
      "default": "Blueprint"
    },
    "blueprint_level": {
      "type": "string",
      "enum": [
        "L1",
        "L2",
        "L3"
      ],
      "default": "L2",
      "description": "Blueprint detail level"
    },
    "novelty_dial": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "default": "medium",
      "description": "Novelty/innovation level"
    },
    "refresh_enabled": {
      "type": "boolean",
      "default": false,
      "description": "Whether external refresh was requested"
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "queued",
        "running",
        "validating",
        "completed",
        "failed"
      ],
      "default": "idle",
      "description": "Run lifecycle status. 'queued' added by IMP-002 emergency backend lane."
    },
    "execution_owner": {
      "type": "string",
      "description": "IMP-002 emergency backend lane \u2014 which side owns execution. 'browser' (legacy /NewQuery path) | 'server' (functions/runJanusPipeline). Optional; absent on legacy runs."
    },
    "queued_at": {
      "type": "string",
      "format": "date-time",
      "description": "IMP-002 \u2014 ISO timestamp when the Run was first inserted as queued. Optional; only set for server-owned runs."
    },
    "claimed_at": {
      "type": "string",
      "format": "date-time",
      "description": "IMP-002 \u2014 ISO timestamp when functions/runJanusPipeline atomically claimed this Run for execution. Optional."
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "IMP-002 \u2014 ISO timestamp when pipeline execution actually began (post-claim). Optional."
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "IMP-002 \u2014 ISO timestamp when the Run reached a terminal status (completed or failed). Optional."
    },
    "reaper_strikes": {
      "type": "number",
      "default": 0,
      "description": "IMP-002 \u2014 count of times an automated reaper has flagged this Run as stalled. Reserved for future use; reaper itself is deferred from emergency scope."
    },
    "validation_errors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Validation errors if any"
    },
    "refresh": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "attempted": {
          "type": "boolean"
        },
        "limitations": {
          "type": "string"
        },
        "would_refresh": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subdomain_updates": {
          "type": "object",
          "description": "Per-subdomain fresh internet research findings (24 keys)",
          "properties": {
            "distributed_systems": {
              "type": "string"
            },
            "data_engineering": {
              "type": "string"
            },
            "cybersecurity": {
              "type": "string"
            },
            "systems_engineering": {
              "type": "string"
            },
            "theoretical_physics": {
              "type": "string"
            },
            "ai_ml": {
              "type": "string"
            },
            "neuroscience": {
              "type": "string"
            },
            "unified_ai_cognitive": {
              "type": "string"
            },
            "knowledge_graphs": {
              "type": "string"
            },
            "epistemology": {
              "type": "string"
            },
            "computational_linguistics": {
              "type": "string"
            },
            "graphrag_reasoning": {
              "type": "string"
            },
            "neuro_symbolic": {
              "type": "string"
            },
            "philosophy_of_mind": {
              "type": "string"
            },
            "jungian_psychology": {
              "type": "string"
            },
            "ethical_ai": {
              "type": "string"
            },
            "hci_empathy": {
              "type": "string"
            },
            "ai_safety": {
              "type": "string"
            },
            "game_theory": {
              "type": "string"
            },
            "mlops_product": {
              "type": "string"
            },
            "agile_scrum": {
              "type": "string"
            },
            "technical_writing": {
              "type": "string"
            },
            "behavioral_economics": {
              "type": "string"
            },
            "api_design": {
              "type": "string"
            }
          }
        },
        "key_developments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sources_consulted": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "training_data_cutoff_note": {
          "type": "string"
        }
      }
    },
    "corpus": {
      "type": "object",
      "properties": {
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "feasibility_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subdomains": {
          "type": "object",
          "description": "Section I \u2014 7 subdomain expert perspectives",
          "properties": {
            "distributed_systems": {
              "type": "object",
              "properties": {
                "perspective": {
                  "type": "string"
                },
                "key_findings": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "data_engineering": {
              "type": "object",
              "properties": {
                "perspective": {
                  "type": "string"
                },
                "key_findings": {
                  "type": "array",
