          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "depends_on_claims": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "inherited_confidence": {
                "type": "string"
              },
              "probability": {
                "type": "string"
              },
              "failure_modes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
