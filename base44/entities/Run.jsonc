            }
          }
        },
        "alignment_engine": {
          "type": "object",
          "description": "Legacy alias for empathy_driven_strategy \u2014 preserved for backward compatibility",
          "properties": {
            "true_goal_vs_literal_prompt": {
              "type": "string"
            },
            "behavioral_model": {
              "type": "string"
            },
            "alignment_strategy": {
              "type": "string"
            }
          }
